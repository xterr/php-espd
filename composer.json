{
    "name": "xterr/php-espd",
    "description": "Typed PHP classes for ESPD (European Single Procurement Document) based on ESPD-EDM v4.1.0 / UBL 2.3",
    "license": "MIT",
    "type": "library",
    "version": "1.4.0",
    "keywords": [
        "ubl",
        "xml",
        "xsd",
        "espd",
        "procurement",
        "e-procurement",
        "qualification"
    ],
    "authors": [
        {
            "name": "Razvan Ceana",
            "email": "razvan@ceana.ro"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-dom": "*",
        "ext-libxml": "*",
        "xterr/php-ubl": "^1.0"
    },
    "bin": ["php-espd"],
    "autoload": {
        "psr-4": {
            "Xterr\\Espd\\": "src/"
        }
    },
    "suggest": {
        "ext-saxonc": "Required for ESPD business rule validation (SaxonC-HE 12.x)"
    },
    "autoload-dev": {
        "psr-4": {
            "Xterr\\Espd\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "xterr/php-ubl-generator": "^1.4",
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "symfony/console": "^7.0 || ^8.0"
    },
    "scripts": {
        "test": "phpunit",
        "analyze": "phpstan analyze"
    }
}
